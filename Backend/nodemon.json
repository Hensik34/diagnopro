{
  "watch": [
    "server.js",
    "routes/",
    "controllers/",
    "models/",
    "services/",
    "middlewere/",
    "config/",
    "db/",
    "utils/"
  ],
  "ignore": [
    "node_modules/",
    "uploads/",
    "*.log",
    ".env",
    ".env.local"
  ],
  "ext": "js,json",
  "delay": 1000,
  "exec": "node server.js"
}
